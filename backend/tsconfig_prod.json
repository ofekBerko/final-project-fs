{
  "compilerOptions": {
    "target": "ES6",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./src" 
  },
  "lib": ["es2015"],
  "include": ["./src/**/*"],
  "exclude": ["./src/tests"]
}